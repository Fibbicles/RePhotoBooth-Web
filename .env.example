# Example environment variables for Re‑Photo Booth
# Copy this file to `.env` and edit values as needed for your local
# development or production deployment.

# Django secret key (required).  Must be a long, random string in
# production.  You can generate one using `python -c "import secrets; print(secrets.token_urlsafe(50))"`.
SECRET_KEY=your-secret-key-here

# Enable Django debug mode (True/False).  Should be False in production.
DEBUG=True

# Comma-separated list of allowed hosts (e.g., example.com,www.example.com).  Leave empty for localhost only.
ALLOWED_HOSTS=localhost,127.0.0.1

# Database configuration (defaults to SQLite if not provided).  For
# PostgreSQL specify:
# DATABASE_URL=postgres://user:password@host:port/dbname

# Email configuration for sending photos (optional).  See Django
# documentation for EMAIL_BACKEND and related settings.
# EMAIL_HOST=mail.example.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=user@example.com
# EMAIL_HOST_PASSWORD=yourpassword
# EMAIL_USE_TLS=True

# Default sender address for outgoing emails.  If unset, Django will
# default to webmaster@localhost.  Override this to a valid address for
# your domain (e.g. no-reply@photobooth.example).
# DEFAULT_FROM_EMAIL=no-reply@example.com

# Name of the printer configured in CUPS for printing photos.  Leave
# empty to disable printing or if printing support is not needed.  This
# should match the printer name visible from `lpstat -p`.
# PHOTOBOOTH_PRINTER=PhotoBooth_Printer

# Additional settings can be added here as the project evolves.